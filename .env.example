# Cloudix es una app Electron: Vite inyecta estas variables en el bundle al compilar.
# O las dos completas (URL + anon key desde InsForge), o ninguna (se usan valores embebidos en código).
# No dejes solo una: provoca advertencia y el cliente ignora el .env parcial por seguridad.
VITE_INSFORGE_BASE_URL=https://tu-backend.insforge.app
VITE_INSFORGE_ANON_KEY=
