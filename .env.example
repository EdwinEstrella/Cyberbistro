# Cyberbistro es una app Electron de escritorio: el renderer se empaqueta con Vite y lee estas
# variables en tiempo de build (inyectadas en el bundle). Copiá a .env en la raíz (no commitear).
# Valores desde el panel InsForge / metadatos del backend.
VITE_INSFORGE_BASE_URL=https://tu-backend.insforge.app
VITE_INSFORGE_ANON_KEY=
